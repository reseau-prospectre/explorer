# GitHub Pages publish set for PROSPECTRE.
# Ignore everything by default, then allow only the static app files.
*

!.gitignore
!.gitattributes
!.nojekyll

!index.html
!app.config.js
!package.json
!package-lock.json

!assets/
!assets/**

!scripts/
!scripts/check-modules.mjs
!scripts/smoke-ui.mjs

!data/
!data/prospectre-documentation/
!data/prospectre-documentation/**
!data/neo/
!data/neo/**
