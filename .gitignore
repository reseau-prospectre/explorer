# GitHub Pages publish set for PROSPECTRE.
# Ignore everything by default, then allow only the static app files.
*

!.gitignore
!.gitattributes
!.nojekyll

!index.html
!app.config.js

!assets/
!assets/**

!scripts/
!scripts/build-prospectre-docs-v2-pack.mjs

!data/
!data/prospectre-documentation/
!data/prospectre-documentation/**
!data/eldoom-cbe/
!data/eldoom-cbe/**
!data/neo/
!data/neo/**
